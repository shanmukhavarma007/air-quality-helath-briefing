{
  "router": {
    "strategy": "capability-based",
    "agents": ["planner", "backend", "frontend", "security", "debugger"]
  },
  "agents": {
    "planner": {
      "model": {
        "primary": "opencode/minimax-m2.5:free",
        "fallback": [
          "opencode/nemotron-3-super:free",
          "opencode/bigpickle:free"
        ]
      },
      "routing": {
        "temperature": 0.4,
        "max_tokens": 3000
      },
      "capabilities": [
        "task-planning",
        "system-design",
        "prd-analysis"
      ]
    },
    "backend": {
      "model": {
        "primary": "opencode/nemotron-3-super:free",
        "fallback": [
          "opencode/minimax-m2.5:free",
          "opencode/bigpickle:free"
        ]
      },
      "routing": {
        "temperature": 0.2,
        "max_tokens": 4000
      },
      "capabilities": [
        "fastapi",
        "async-python",
        "sql",
        "redis",
        "celery",
        "api-integration",
        "ai-service"
      ],
      "constraints": [
        "never_modify_frontend",
        "enforce_ai_quota",
        "use_async_everywhere"
      ]
    },
    "frontend": {
      "model": {
        "primary": "opencode/bigpickle:free",
        "fallback": [
          "opencode/minimax-m2.5:free",
          "opencode/nemotron-3-super:free"
        ]
      },
      "routing": {
        "temperature": 0.5,
        "max_tokens": 3000
      },
      "capabilities": [
        "react",
        "ui-design",
        "tailwind",
        "state-management",
        "api-integration"
      ]
    },
    "security": {
      "model": {
        "primary": "opencode/nemotron-3-super:free",
        "fallback": [
          "opencode/minimax-m2.5:free"
        ]
      },
      "routing": {
        "temperature": 0.1,
        "max_tokens": 3000
      },
      "capabilities": [
        "security-audit",
        "jwt",
        "auth-validation",
        "rate-limiting",
        "input-sanitization",
        "owasp"
      ]
    },
    "debugger": {
      "model": {
        "primary": "opencode/minimax-m2.5:free",
        "fallback": [
          "opencode/nemotron-3-super:free",
          "opencode/bigpickle:free"
        ]
      },
      "routing": {
        "temperature": 0.2,
        "max_tokens": 3000
      },
      "capabilities": [
        "bug-fixing",
        "log-analysis",
        "test-generation",
        "performance-debugging"
      ]
    }
  }
}